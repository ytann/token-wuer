{
  "manifest_version": 3,
  "name": "Water Calculator",
  "version": "0.1.0",
  "description": "Track water consumption of your LLM conversations",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-DP2rzg_V.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ]
    }
  ],
  "options_page": "src/options/index.html",
  "web_accessible_resources": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "resources": [
        "assets/index.ts-DP2rzg_V.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
